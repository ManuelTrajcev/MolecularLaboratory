# =============================================================================
# Unity 6 (Unity 6000.x) — generated, cache, and per-user files
# =============================================================================

# Editor caches and generated output
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
[Pp]rofilerCaptures/
.codex

# Unity 6 incremental build cache and reports (can grow to multiple GB)
[Bb]ee/
[Bb]uild[Rr]eports/
[Aa]rtifacts/

# Unity Test Runner output and code coverage
[Cc]odeCoverage/
[Tt]estResults/

# Burst compiler cache
[Bb]urst[Cc]ache/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/
.vsconfig

# Gradle cache directory
.gradle/

# Autogenerated VS / MD / Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt
mono_crash.*

# Builds (Quest / standalone artifacts)
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# =============================================================================
# JetBrains Rider
# =============================================================================
.idea/

# =============================================================================
# OS junk
# =============================================================================
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# =============================================================================
# Common large/unwanted artifacts that occasionally land in the repo
# =============================================================================
*.zip
*.7z
*.rar
*.tar
*.tar.gz
*.tgz
*.dmg
*.iso
*.bak
*.tmp
*.swp
*~

# =============================================================================
# Claude Code — commit project rules and hooks, ignore personal local overrides
# =============================================================================
.claude/settings.local.json

.vscode/*
